{% comment %}
  Menu Bottom Sheet — Full Black Overlay
  - Open with [data-open-sheet-target="<sheet_id>"]
  - Overlay: solid black, fades in/out
  - Panel: slides up/down
  - Header: Title left, close button right
  - Body: Renders a selected Shopify Menu with nested accordions for submenus
{% endcomment %}

{% assign sheet_id = section.settings.sheet_id | strip %}
{% if sheet_id == blank %}
  {% assign sheet_id = 'custom-dawn-menu' %}
{% endif %}

{% style %}
  :root { --qc-sheet-z: 2147483646; }

  .qc-bottom-sheet {
    position: fixed;
    inset: 0;
    z-index: var(--qc-sheet-z);
    pointer-events: none;
  }
  .qc-bottom-sheet.is-open { pointer-events: auto; }

  .qc-bottom-sheet__overlay {
    position: fixed;
    inset: 0;
    background: #000; /* solid black */
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
    z-index: 0;
  }
  .qc-bottom-sheet.is-open .qc-bottom-sheet__overlay {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease;
  }

  .qc-bottom-sheet__panel {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 1;
    background: {{ section.settings.panel_bg }};
    border-top-left-radius: {{ section.settings.panel_radius }}px;
    border-top-right-radius: {{ section.settings.panel_radius }}px;
    max-height: calc(85vh + env(safe-area-inset-bottom));
    display: flex;
    flex-direction: column;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.18);
    padding: 16px 16px calc(16px + env(safe-area-inset-bottom));
  }
  .qc-bottom-sheet.is-open .qc-bottom-sheet__panel {
    transform: translateY(0);
  }

  .bottom-sheet-open { overflow: hidden; touch-action: none; }

  .qc-bottom-sheet__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
    flex-shrink: 0;
  }
  .qc-bottom-sheet__title {
    font-size: 18px;
    font-weight: 600;
    margin: 0;
  }
  .qc-bottom-sheet__close {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
  }

  /* Menu Styles */
  .qc-bottom-sheet__menu-wrapper {
    overflow-y: auto; /* Allows scrolling if menu is long */
    -webkit-overflow-scrolling: touch;
  }

  .qc-menu-list, 
  .qc-submenu-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .qc-menu-link,
  .qc-menu-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 14px 0;
    text-decoration: none;
    color: inherit;
    font-size: 16px;
    font-weight: 500;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    background: transparent;
    cursor: pointer;
  }

  /* Submenu styling */
  .qc-submenu-list {
    padding-left: 16px;
    background: rgba(0,0,0,0.02);
  }
  .qc-menu-link--child,
  .qc-menu-summary--child {
    font-size: 15px;
    font-weight: 400;
    padding: 12px 0;
  }

  /* Accordion details */
  .qc-menu-details summary {
    list-style: none;
  }
  .qc-menu-details summary::-webkit-details-marker {
    display: none;
  }
  .qc-menu-icon {
    font-size: 10px;
    transition: transform 0.3s ease;
  }
  .qc-menu-details[open] > .qc-menu-summary .qc-menu-icon {
    transform: rotate(180deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .qc-bottom-sheet__overlay { transition: none; }
    .qc-bottom-sheet__panel { transition: none; }
  }
{% endstyle %}

<div id="{{ sheet_id }}" class="qc-bottom-sheet" data-sheet aria-hidden="true">
  <div class="qc-bottom-sheet__overlay" data-close></div>

  <div class="qc-bottom-sheet__panel" role="dialog" aria-modal="true" aria-labelledby="{{ sheet_id }}-title">
    <div class="qc-bottom-sheet__header">
      <div id="{{ sheet_id }}-title" class="qc-bottom-sheet__title">
        {{ section.settings.title | default: "Menu" }}
      </div>
      <button type="button" class="qc-bottom-sheet__close" aria-label="Close" data-close>
        <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content | default: 'X' }}</span>
      </button>
    </div>

    <div class="qc-bottom-sheet__menu-wrapper">
      {%- if section.settings.menu != blank -%}
        <ul class="qc-menu-list">
          {%- for link in section.settings.menu.links -%}
            <li class="qc-menu-item">
              {%- if link.links != blank -%}
                <details class="qc-menu-details">
                  <summary class="qc-menu-summary">
                    {{ link.title }}
                    <span class="qc-menu-icon">▼</span>
                  </summary>
                  <ul class="qc-submenu-list">
                    {%- for childlink in link.links -%}
                      <li class="qc-submenu-item">
                        {%- if childlink.links != blank -%}
                          <details class="qc-menu-details">
                            <summary class="qc-menu-summary qc-menu-summary--child">
                              {{ childlink.title }}
                              <span class="qc-menu-icon">▼</span>
                            </summary>
                            <ul class="qc-submenu-list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a href="{{ grandchildlink.url }}" class="qc-menu-link qc-menu-link--child" style="padding-left: 16px;">
                                    {{ grandchildlink.title }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          </details>
                        {%- else -%}
                          <a href="{{ childlink.url }}" class="qc-menu-link qc-menu-link--child">{{ childlink.title }}</a>
                        {%- endif -%}
                      </li>
                    {%- endfor -%}
                  </ul>
                </details>
              {%- else -%}
                <a href="{{ link.url }}" class="qc-menu-link">{{ link.title }}</a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p style="padding: 20px 0; text-align: center; opacity: 0.6;">Please select a menu in the theme settings.</p>
      {%- endif -%}
    </div>
  </div>

  <script>
    (function(){
      var root = document.getElementById({{ sheet_id | json }});
      if (!root) return;
      var id = {{ sheet_id | json }};
      var overlay = root.querySelector('.qc-bottom-sheet__overlay');
      var closeBtns = root.querySelectorAll('[data-close]');

      function openSheet(){
        root.classList.add('is-open');
        root.setAttribute('aria-hidden', 'false');
        document.body.classList.add('bottom-sheet-open');
      }

      function closeSheet(){
        root.classList.remove('is-open');
        root.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('bottom-sheet-open');
      }

      closeBtns.forEach(function(btn){ btn.addEventListener('click', closeSheet); });
      if (overlay) overlay.addEventListener('click', closeSheet);

      document.addEventListener('keydown', function(e){
        if (e.key === 'Escape') closeSheet();
      });

      document.addEventListener('click', function(e){
        var opener = e.target.closest('[data-open-sheet-target]');
        if (!opener) return;
        var targetId = opener.getAttribute('data-open-sheet-target');
        if (targetId === id) {
          e.preventDefault();
          openSheet();
        }
      });
    })();
  </script>
</div>

{% schema %}
{
  "name": "Menu bottom sheet",
  "settings": [
    { 
      "type": "text", 
      "id": "sheet_id", 
      "label": "Sheet ID", 
      "default": "custom-dawn-menu",
      "info": "Use this ID in triggers (data-open-sheet-target)." 
    },
    { 
      "type": "text", 
      "id": "title", 
      "label": "Header Title", 
      "default": "Menu" 
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Menu",
      "default": "main-menu"
    },
    { 
      "type": "color", 
      "id": "panel_bg", 
      "label": "Panel background", 
      "default": "#ffffff" 
    },
    { 
      "type": "range", 
      "id": "panel_radius", 
      "label": "Panel corner radius", 
      "min": 0, 
      "max": 32, 
      "step": 2, 
      "unit": "px", 
      "default": 16 
    }
  ],
  "presets": [
    { "name": "Menu bottom sheet" }
  ]
}
{% endschema %}