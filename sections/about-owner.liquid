{% schema %}
{
  "name": "About Owner",
  "settings": [
    {
      "type": "image_picker",
      "id": "owner_image",
      "label": "Owner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the Founder"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Write something compelling about the owner. Their journey, vision, and what makes the brand special."
    },

    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#EAEAEA"
    },

    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Paragraph Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },

    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "About Owner"
    }
  ]
}
{% endschema %}

<div 
  class="about-owner"
  style="
    --bg: {{ section.settings.bg_color }};
    --text: {{ section.settings.text_color }};
    --heading-size: {{ section.settings.heading_size }}px;
    --text-size: {{ section.settings.text_size }}px;

    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  <div class="about-owner-inner page-width">

    <!-- LEFT IMAGE -->
    <div class="ao-image">
      {% if section.settings.owner_image %}
        <img 
          src="{{ section.settings.owner_image | image_url: width: 900 }}"
          alt="Owner Image"
          loading="lazy"
        >
      {% endif %}
    </div>

    <!-- RIGHT CONTENT -->
    <div class="ao-content">
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.description }}</p>
    </div>

  </div>

</div>

<style>
.about-owner {
  background: var(--bg);
  color: var(--text);
}

/* LAYOUT */
.about-owner-inner {
  display: grid;
  grid-template-columns: 40% 60%;
  gap: 60px;
  align-items: center;
}

/* IMAGE */
.ao-image {
  position: relative;
}

/* Creative accent */
.ao-image::after {
  content: "";
  position: absolute;
  inset: 10% -10% -10% 10%;
  background: rgba(193,122,90,0.15);
  z-index: 0;
  border-radius: 20px;
}

.ao-image img {
  width: 100%;
  height: auto; /* 🔥 Adapt to image */
  display: block;
  position: relative;
  z-index: 1;
  border-radius: 12px;
}

/* CONTENT */
.ao-content {
  max-width: 600px;
}

.ao-content h2 {
  font-size: var(--heading-size);
  margin-bottom: 15px;
  line-height: 1.2;
}

.ao-content p {
  font-size: var(--text-size);
  line-height: 1.7;
  opacity: 0.9;
}

/* MOBILE */
@media (max-width: 768px) {
  .about-owner-inner {
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .ao-content {
    text-align: center;
  }
}
</style>