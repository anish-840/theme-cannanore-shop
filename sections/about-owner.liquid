{% schema %}
{
  "name": "About Owner",
  "settings": [
    {
      "type": "image_picker",
      "id": "owner_image",
      "label": "Owner Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image Border Radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Removing Friction from the Everyday"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Designing to create intuitive spaces where technology feels less like a tool and more like a seamless extension of thought. Welcome to a premium, user-centered experience."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#EAEAEA"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Header Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Header Font Size",
      "min": 20,
      "max": 60,
      "step": 2,
      "default": 36
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Paragraph Size",
      "min": 12,
      "max": 24,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number",
          "default": "10+"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Stat Label",
          "default": "Projects Completed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Owner",
      "blocks": [
        { "type": "stat", "settings": { "stat_number": "5+", "stat_label": "Years Experience" } },
        { "type": "stat", "settings": { "stat_number": "100%", "stat_label": "User Centered" } }
      ]
    }
  ]
}
{% endschema %}

<div 
  class="about-owner"
  style="
    --bg: {{ section.settings.bg_color }};
    --text: {{ section.settings.text_color }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-size: {{ section.settings.heading_size }}px;
    --text-size: {{ section.settings.text_size }}px;
    --image-radius: {{ section.settings.image_border_radius }}px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  <div class="about-owner-inner page-width">

    <div class="ao-image fade-in-up">
      {% if section.settings.owner_image %}
        <img 
          src="{{ section.settings.owner_image | image_url: width: 900 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>

    <div class="ao-content">
      <h2 class="fade-in-up" style="animation-delay: 0.1s;">{{ section.settings.heading }}</h2>
      <p class="fade-in-up" style="animation-delay: 0.2s;">{{ section.settings.description }}</p>

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <div class="fade-in-up" style="animation-delay: 0.25s;">
          <a href="{{ section.settings.button_link }}" class="ao-button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="ao-stats fade-in-up" style="animation-delay: 0.35s;">
          {% for block in section.blocks %}
            <div class="ao-stat-item" {{ block.shopify_attributes }}>
              <h3>{{ block.settings.stat_number }}</h3>
              <span>{{ block.settings.stat_label }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>

</div>

<style>
.about-owner {
  background: var(--bg);
  color: var(--text);
  overflow: hidden;
}

/* LAYOUT */
.about-owner-inner {
  display: grid;
  grid-template-columns: 40% 60%;
  gap: 60px;
  align-items: center;
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

/* IMAGE */
.ao-image {
  position: relative;
  border-radius: var(--image-radius);
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.2);
  /* Smooth zoom container */
  transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.ao-image:hover {
  transform: scale(1.02);
}

.ao-image img, .ao-image svg {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
  background-color: #1a1a1a;
}

/* CONTENT */
.ao-content {
  max-width: 600px;
}

.ao-content h2 {
  font-size: var(--heading-size);
  color: var(--heading-color);
  margin-bottom: 20px;
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.ao-content p {
  font-size: var(--text-size);
  line-height: 1.6;
  opacity: 0.85;
  margin-bottom: 25px; /* Reduced to make room for button */
}

/* BUTTON */
.ao-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12px 32px;
  margin-bottom: 40px;
  background-color: var(--heading-color);
  color: var(--bg);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  border-radius: 30px;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
}

.ao-button:hover {
  transform: translateY(-2px);
  opacity: 0.95;
}

/* STATS */
.ao-stats {
  display: flex;
  gap: 40px;
  flex-wrap: wrap;
  border-top: 1px solid rgba(255, 255, 255, 0.1); /* Subtle divider */
  padding-top: 30px;
}

.ao-stat-item h3 {
  font-size: 32px;
  color: var(--heading-color);
  margin: 0 0 5px 0;
  line-height: 1;
  font-weight: 600;
}

.ao-stat-item span {
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  opacity: 0.6;
  font-weight: 500;
}

/* ANIMATIONS */
.fade-in-up {
  opacity: 0;
  transform: translateY(30px);
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes fadeInUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* MOBILE */
@media (max-width: 768px) {
  .about-owner-inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }

  .ao-content {
    text-align: left; /* Keep left aligned for a premium look */
  }
  
  .ao-stats {
    gap: 30px;
  }
}
</style>