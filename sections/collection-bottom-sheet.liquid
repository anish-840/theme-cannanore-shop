{% comment %}
  Collection Bottom Sheet — Full Black Overlay
  - Open with [data-open-sheet-target="<sheet_id>"]
  - Overlay: solid black, fades in/out
  - Panel: slides up/down
  - Header: Title left, close button right
{% endcomment %}

{% assign sheet_id = section.settings.sheet_id | strip %}
{% if sheet_id == blank %}
  {% assign sheet_id = 'bottom-sheet-' | append: section.id %}
{% endif %}

{% style %}
  :root { --qc-sheet-z: 2147483646; }

  .qc-bottom-sheet {
    position: fixed;
    inset: 0;
    z-index: var(--qc-sheet-z);
    pointer-events: none;
  }
  .qc-bottom-sheet.is-open { pointer-events: auto; }

  .qc-bottom-sheet__overlay {
    position: fixed;
    inset: 0;
    background: #000; /* solid black */
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0s linear 0.3s;
    z-index: 0;
  }
  .qc-bottom-sheet.is-open .qc-bottom-sheet__overlay {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.3s ease;
  }

  .qc-bottom-sheet__panel {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 1;
    background: {{ section.settings.panel_bg }};
    border-top-left-radius: {{ section.settings.panel_radius }}px;
    border-top-right-radius: {{ section.settings.panel_radius }}px;
    max-height: calc(85vh + env(safe-area-inset-bottom));
    transform: translateY(100%);
    transition: transform 0.3s ease;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.18);
    padding: 16px 16px calc(16px + env(safe-area-inset-bottom));
  }
  .qc-bottom-sheet.is-open .qc-bottom-sheet__panel {
    transform: translateY(0);
  }

  .bottom-sheet-open { overflow: hidden; touch-action: none; }

  .qc-bottom-sheet__header {
    display: flex;
    align-items: center;
    justify-content: space-between; /* ✅ Title left, Close right */
    gap: 8px;
    margin-bottom: 8px;
  }
  .qc-bottom-sheet__title {
    font-size: 16px;
    font-weight: 600;
  }
  .qc-bottom-sheet__close {
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 8px;
    line-height: 1;
  }

  .qc-bottom-sheet__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }
  @media (min-width: 750px) {
    .qc-bottom-sheet__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }

  .qc-col-item { text-align: center; }
  .qc-col-link { display: block; text-decoration: none; color: inherit; }
  .qc-col-imgwrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #f6f6f6;
  }
  .qc-shape-square { border-radius: 0; }
  .qc-shape-rounded { border-radius: 12px; }
  .qc-shape-circle { border-radius: 9999px; }
  .qc-shape-soft { border-radius: 24px; }
  .qc-col-imgwrap img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .qc-col-title { margin-top: 8px; font-weight: 500; }

  @media (prefers-reduced-motion: reduce) {
    .qc-bottom-sheet__overlay { transition: none; }
    .qc-bottom-sheet__panel { transition: none; }
  }
{% endstyle %}

<div id="{{ sheet_id }}" class="qc-bottom-sheet" data-sheet aria-hidden="true">
  <div class="qc-bottom-sheet__overlay" data-close></div>

  <div class="qc-bottom-sheet__panel" role="dialog" aria-modal="true" aria-labelledby="{{ sheet_id }}-title">
    <div class="qc-bottom-sheet__header">
      <div id="{{ sheet_id }}-title" class="qc-bottom-sheet__title">
        {{ section.settings.title | default: "Collections" }}
      </div>
      <button type="button" class="qc-bottom-sheet__close" aria-label="Close" data-close>
        <span class="svg-wrapper">{{ 'icon-close.svg' | inline_asset_content }}</span>
      </button>
    </div>

    <div class="qc-bottom-sheet__grid">
      {% for block in section.blocks %}
        {% assign col = block.settings.collection %}
        {% if col == blank %}{% continue %}{% endif %}
        {% assign img = block.settings.custom_image | default: col.featured_image %}
        {% assign shape = block.settings.image_shape | default: 'rounded' %}
        <div class="qc-col-item" {{ block.shopify_attributes }}>
          <a class="qc-col-link" href="{{ col.url }}">
            <div class="qc-col-imgwrap qc-shape-{{ shape }}">
              {% if img %}
                <img src="{{ img | image_url: width: 600 }}" alt="{{ col.title | escape }}" loading="lazy">
              {% endif %}
            </div>
            <div class="qc-col-title" style="color: {{ block.settings.name_color }}; font-size: {{ block.settings.name_size }}px;">
              {{ col.title }}
            </div>
          </a>
        </div>
      {% endfor %}
    </div>
  </div>

  <script>
    (function(){
      var root = document.getElementById({{ sheet_id | json }});
      if (!root) return;
      var id = {{ sheet_id | json }};
      var overlay = root.querySelector('.qc-bottom-sheet__overlay');
      var closeBtns = root.querySelectorAll('[data-close]');

      function openSheet(){
        root.classList.add('is-open');
        root.setAttribute('aria-hidden', 'false');
        document.body.classList.add('bottom-sheet-open');
      }

      function closeSheet(){
        root.classList.remove('is-open');
        root.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('bottom-sheet-open');
      }

      closeBtns.forEach(function(btn){ btn.addEventListener('click', closeSheet); });
      if (overlay) overlay.addEventListener('click', closeSheet);

      document.addEventListener('keydown', function(e){
        if (e.key === 'Escape') closeSheet();
      });

      document.addEventListener('click', function(e){
        var opener = e.target.closest('[data-open-sheet-target]');
        if (!opener) return;
        var targetId = opener.getAttribute('data-open-sheet-target');
        if (targetId === id) {
          e.preventDefault();
          openSheet();
        }
      });
    })();
  </script>
</div>

{% schema %}
{
  "name": "Collection bottom sheet",
  "settings": [
    { "type": "text", "id": "sheet_id", "label": "Sheet ID", "info": "Leave blank to auto-generate. Use this ID in triggers (data-open-sheet-target)." },
    { "type": "text", "id": "title", "label": "Title", "default": "Collections" },
    { "type": "color", "id": "panel_bg", "label": "Panel background", "default": "#ffffff" },
    { "type": "range", "id": "panel_radius", "label": "Panel corner radius", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 16 },
    { "type": "range", "id": "columns_mobile", "label": "Columns (mobile)", "min": 2, "max": 4, "step": 1, "default": 3 },
    { "type": "range", "id": "columns_desktop", "label": "Columns (desktop)", "min": 3, "max": 6, "step": 1, "default": 4 },
    { "type": "range", "id": "grid_gap", "label": "Grid gap", "min": 4, "max": 28, "step": 2, "unit": "px", "default": 12 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "custom_image", "label": "Override image" },
        { "type": "select", "id": "image_shape", "label": "Image shape", "options": [
          { "value": "square", "label": "Square" },
          { "value": "rounded", "label": "Rounded" },
          { "value": "circle", "label": "Circle" },
          { "value": "soft", "label": "Soft rounded" }
        ], "default": "rounded" },
        { "type": "color", "id": "name_color", "label": "Name color", "default": "#111111" },
        { "type": "range", "id": "name_size", "label": "Name font size", "min": 10, "max": 24, "step": 1, "unit": "px", "default": 12 }
      ]
    }
  ],
  "presets": [
    { "name": "Collection bottom sheet", "blocks": [ { "type": "collection" }, { "type": "collection" }, { "type": "collection" } ] }
  ]
}
{% endschema %}
