{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Dynamic Alignments */
  #CustomMenu-{{ section.id }} .custom-menu-list {
    justify-content: {{ section.settings.menu_alignment }};
  }
  #CustomMenu-{{ section.id }} .h2 {
    text-align: {% if section.settings.menu_alignment == 'flex-start' %}left{% elsif section.settings.menu_alignment == 'flex-end' %}right{% else %}center{% endif %};
  }

  /* Dynamic Typography & Colors */
  #CustomMenu-{{ section.id }} .custom-menu-item .link, 
  #CustomMenu-{{ section.id }} .h2 {
    font-style: {{ section.settings.font_style }};
    font-weight: {{ section.settings.font_weight }};
    {% if section.settings.text_color != blank and section.settings.text_color != 'rgba(0,0,0,0)' %}
      color: {{ section.settings.text_color }};
    {% endif %}
  }

  /* Keep submenu link weights normal unless overridden, but inherit color */
  #CustomMenu-{{ section.id }} .custom-submenu-item .link {
    font-weight: 400; 
  }

  /* Dynamic Submenu Padding */
  #CustomMenu-{{ section.id }} .custom-submenu {
    padding: {{ section.settings.submenu_padding_tb }}px 15px {{ section.settings.submenu_padding_tb }}px {{ section.settings.submenu_padding_left }}px;
  }
{%- endstyle -%}

<div id="CustomMenu-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="custom-menu-section page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="h2">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.menu != blank -%}
      <ul class="custom-menu-list list-unstyled">
        {%- for link in section.settings.menu.links -%}
          <li class="custom-menu-item {% if link.links != blank %}has-dropdown{% endif %}">
            
            <a href="{{ link.url }}" class="link">
              {{ link.title }}
              {%- if link.links != blank and section.settings.dropdown_icon != 'none' -%}
                <span class="dropdown-caret">{{ section.settings.dropdown_icon }}</span>
              {%- endif -%}
            </a>
            
            {%- comment -%} Dropdown Menu {%- endcomment -%}
            {%- if link.links != blank -%}
              <ul class="custom-submenu list-unstyled color-{{ section.settings.color_scheme }} gradient">
                {%- for child_link in link.links -%}
                  <li class="custom-submenu-item">
                    <a href="{{ child_link.url }}" class="link">{{ child_link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}

          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <p style="text-align: center;">Please select a menu in the theme editor.</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Custom Menu Dropdown",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Menu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Menu"
    },
    {
      "type": "header",
      "content": "Layout & Alignment"
    },
    {
      "type": "select",
      "id": "menu_alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Dropdown Options"
    },
    {
      "type": "select",
      "id": "dropdown_icon",
      "label": "Dropdown icon",
      "options": [
        { "value": "▼", "label": "Caret (▼)" },
        { "value": "+", "label": "Plus (+)" },
        { "value": "↓", "label": "Arrow (↓)" },
        { "value": "none", "label": "None" }
      ],
      "default": "▼"
    },
    {
      "type": "range",
      "id": "submenu_padding_left",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Dropdown left padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "submenu_padding_tb",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Dropdown top/bottom padding",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color override",
      "info": "Overrides the color scheme text color if selected."
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "font_style",
      "label": "Font style",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "italic", "label": "Italic" }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Custom Menu Dropdown"
    }
  ]
}
{% endschema %}

{% stylesheet %}
  /* Make the top-level menu horizontal */
  .custom-menu-list {
    display: flex;
    gap: 30px;
    flex-wrap: wrap;
    position: relative;
    margin: 0;
    padding: 0;
  }

  /* Set up the parent item as an anchor for the dropdown */
  .custom-menu-item {
    position: relative;
    list-style: none;
    padding-bottom: 15px; /* Creates an invisible hover bridge to the dropdown */
  }

  .custom-menu-item .link {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .dropdown-caret {
    font-size: 0.7em;
  }

  /* The Dropdown Box (Hidden by default) */
  .custom-submenu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    border: 1px solid rgba(0,0,0,0.05);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
    min-width: 220px;
    z-index: 10;
  }

  /* Show the dropdown when hovering over the parent item */
  .custom-menu-item.has-dropdown:hover .custom-submenu {
    display: block;
  }

  /* Styling for the links inside the dropdown */
  .custom-submenu-item {
    list-style: none;
    margin-bottom: 10px;
  }

  .custom-submenu-item:last-child {
    margin-bottom: 0;
  }

  .custom-submenu-item .link {
    text-decoration: none;
    display: block;
    width: 100%;
    opacity: 0.85; /* Slight fade for hierarchy */
    transition: opacity 0.2s ease;
  }

  .custom-submenu-item .link:hover {
    text-decoration: underline;
    opacity: 1;
  }
{% endstylesheet %}