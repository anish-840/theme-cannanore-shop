{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "New Arrivals"
    },
    {
      "type": "url",
      "id": "all_products_link",
      "label": "All Products Link"
    },
    {
      "type": "text",
      "id": "all_products_text",
      "label": "All Products Text",
      "default": "View All"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    },

    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#C17A5A"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 6
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Grid Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Arrivals",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}

<div 
  class="new-arrivals page-width"
  style="
    --btn-bg: {{ section.settings.btn_bg }};
    --btn-text: {{ section.settings.btn_text }};
    --btn-radius: {{ section.settings.btn_radius }}px;
  "
>

  <!-- Header -->
  <div class="na-header">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.all_products_link != blank %}
      <a href="{{ section.settings.all_products_link }}" class="na-link">
        {{ section.settings.all_products_text }}
      </a>
    {% endif %}
  </div>

  <div class="na-grid">

    <!-- LEFT FEATURED -->
    <div class="na-featured">
      {% assign product = all_products[section.settings.featured_product] %}
      {% if product %}
        <div class="na-card">

          <div class="na-image-wrapper">
            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url: width: 900 }}" alt="{{ product.title }}">
            </a>

            <!-- Overlay -->
            <div class="na-overlay">
              <form method="post" action="/cart/add">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit">Add to Cart</button>
              </form>
            </div>
          </div>

          <div class="na-info">
            <h3>{{ product.title }}</h3>
            <span>{{ product.price | money }}</span>
          </div>

        </div>
      {% endif %}
    </div>

    <!-- RIGHT GRID -->
    <div class="na-products">
      {% for block in section.blocks %}
        {% assign p = all_products[block.settings.product] %}
        {% if p %}
          <div class="na-card">

            <div class="na-image-wrapper">
              <a href="{{ p.url }}">
                <img src="{{ p.featured_image | image_url: width: 600 }}" alt="{{ p.title }}">
              </a>

              <!-- Overlay (FIXED) -->
              <div class="na-overlay">
                <form method="post" action="/cart/add">
                  <input type="hidden" name="id" value="{{ p.variants.first.id }}">
                  <button type="submit">Add to Cart</button>
                </form>
              </div>
            </div>

            <div class="na-info">
              <h4>{{ p.title }}</h4>
              <span>{{ p.price | money }}</span>
            </div>

          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
.na-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

.na-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* RIGHT GRID */
.na-products {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

/* CARD */
.na-card {
  position: relative;
}

/* IMAGE WRAPPER (CRITICAL FIX) */
.na-image-wrapper {
  position: relative;
  overflow: hidden;
}

.na-image-wrapper img {
  width: 100%;
  display: block;
}

/* OVERLAY */
.na-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0,0,0,0.25);

  opacity: 0;
  transition: 0.3s ease;
  z-index: 2;
}

/* BUTTON */
.na-overlay button {
  background: var(--btn-bg);
  color: var(--btn-text);
  border: none;
  padding: 12px 20px;
  border-radius: var(--btn-radius);
  cursor: pointer;
}

/* HOVER */
.na-image-wrapper:hover .na-overlay {
  opacity: 1;
}

/* INFO */
.na-info {
  margin-top: 8px;
}

.na-info h3,
.na-info h4 {
  margin: 0;
  font-size: 16px;
}

/* MOBILE */
@media (max-width: 768px) {
  .na-grid {
    grid-template-columns: 1fr;
  }
}
</style>