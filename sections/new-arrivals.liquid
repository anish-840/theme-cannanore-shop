{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "New Arrivals"
    },
    {
      "type": "url",
      "id": "all_products_link",
      "label": "All Products Link"
    },
    {
      "type": "text",
      "id": "all_products_text",
      "label": "All Products Text",
      "default": "View All"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Grid Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Arrivals",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}

<div class="new-arrivals-section page-width">

  <!-- Header -->
  <div class="na-header">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.all_products_link != blank %}
      <a href="{{ section.settings.all_products_link }}" class="na-link">
        {{ section.settings.all_products_text }}
      </a>
    {% endif %}
  </div>

  <div class="na-grid">

    <!-- LEFT: FEATURED -->
    <div class="na-featured">
      {% assign product = all_products[section.settings.featured_product] %}
      {% if product %}
        <div class="na-card featured-card">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title }}">
          </a>

          <div class="na-info">
            <h3>{{ product.title }}</h3>
            <span>{{ product.price | money }}</span>
          </div>

          <form method="post" action="/cart/add" class="na-atc">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button type="submit">Add to Cart</button>
          </form>
        </div>
      {% endif %}
    </div>

    <!-- RIGHT: GRID -->
    <div class="na-products">
      {% for block in section.blocks %}
        {% assign p = all_products[block.settings.product] %}
        {% if p %}
          <div class="na-card">
            <a href="{{ p.url }}">
              <img src="{{ p.featured_image | image_url: width: 500 }}" alt="{{ p.title }}">
            </a>

            <div class="na-info">
              <h4>{{ p.title }}</h4>
              <span>{{ p.price | money }}</span>
            </div>

            <form method="post" action="/cart/add" class="na-atc">
              <input type="hidden" name="id" value="{{ p.variants.first.id }}">
              <button type="submit">Add to Cart</button>
            </form>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
.new-arrivals-section {
  padding: 40px 0;
}

/* Header */
.na-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25px;
}

.na-header h2 {
  font-size: 24px;
}

.na-link {
  text-decoration: none;
  font-size: 14px;
}

/* Layout */
.na-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* Featured */
.na-featured img {
  width: 100%;
  height: auto;
}

/* Right grid */
.na-products {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

/* Card */
.na-card {
  position: relative;
  overflow: hidden;
}

.na-card img {
  width: 100%;
  display: block;
}

.na-info {
  margin-top: 8px;
}

.na-info h3,
.na-info h4 {
  font-size: 16px;
  margin: 0;
}

/* Add to Cart */
.na-atc {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  opacity: 0;
  transition: 0.3s ease;
}

.na-atc button {
  padding: 10px 16px;
  border: none;
  cursor: pointer;
}

/* Hover Effect */
.na-card:hover .na-atc {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* Mobile */
@media screen and (max-width: 768px) {
  .na-grid {
    grid-template-columns: 1fr;
  }

  .na-products {
    grid-template-columns: 1fr 1fr;
  }
}
</style>