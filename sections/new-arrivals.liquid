{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "New Arrivals"
    },
    {
      "type": "url",
      "id": "all_products_link",
      "label": "All Products Link"
    },
    {
      "type": "text",
      "id": "all_products_text",
      "label": "All Products Text",
      "default": "View All"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    },

    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#C17A5A"
    },
    {
      "type": "color",
      "id": "btn_text",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 6
    },
    {
      "type": "select",
      "id": "btn_position",
      "label": "Button Position",
      "default": "center",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "center-left", "label": "Center Left" },
        { "value": "center", "label": "Center" },
        { "value": "center-right", "label": "Center Right" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-center", "label": "Bottom Center" },
        { "value": "bottom-right", "label": "Bottom Right" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Grid Product",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}

<div 
  class="new-arrivals page-width"
  data-position="{{ section.settings.btn_position }}"
  style="
    --btn-bg: {{ section.settings.btn_bg }};
    --btn-text: {{ section.settings.btn_text }};
    --btn-radius: {{ section.settings.btn_radius }}px;
  "
>

  <!-- Header -->
  <div class="na-header">
    <h2>{{ section.settings.heading }}</h2>
    {% if section.settings.all_products_link != blank %}
      <a href="{{ section.settings.all_products_link }}">
        {{ section.settings.all_products_text }}
      </a>
    {% endif %}
  </div>

  <div class="na-grid">

    <!-- FEATURED -->
    <div class="na-featured">
      {% assign product = all_products[section.settings.featured_product] %}
      {% if product %}
        <div class="na-card">
          <div class="na-image-wrapper">

            <a href="{{ product.url }}">
              <img src="{{ product.featured_image | image_url: width: 900 }}">
            </a>

            <div class="na-overlay">
              <form class="na-atc-form">
                <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                <button type="submit">Add to Cart</button>
              </form>
            </div>

          </div>

          <div class="na-info">
            <h3>{{ product.title }}</h3>
            <span>{{ product.price | money }}</span>
          </div>
        </div>
      {% endif %}
    </div>

    <!-- GRID -->
    <div class="na-products">
      {% for block in section.blocks %}
        {% assign p = all_products[block.settings.product] %}
        {% if p %}
          <div class="na-card">
            <div class="na-image-wrapper">

              <a href="{{ p.url }}">
                <img src="{{ p.featured_image | image_url: width: 600 }}">
              </a>

              <div class="na-overlay">
                <form class="na-atc-form">
                  <input type="hidden" name="id" value="{{ p.variants.first.id }}">
                  <button type="submit">Add to Cart</button>
                </form>
              </div>

            </div>

            <div class="na-info">
              <h4>{{ p.title }}</h4>
              <span>{{ p.price | money }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
.na-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20px;
}

.na-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.na-products {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 15px;
}

.na-image-wrapper {
  position: relative;
}

.na-image-wrapper img {
  width: 100%;
  display: block;
}

/* Overlay */
.na-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  padding: 15px;
  background: rgba(0,0,0,0.25);
  opacity: 0;
  transition: 0.3s ease;
}

/* Button */
.na-overlay button {
  background: var(--btn-bg);
  color: var(--btn-text);
  border-radius: var(--btn-radius);
  border: none;
  padding: 10px 18px;
  cursor: pointer;
}

/* Hover */
.na-image-wrapper:hover .na-overlay {
  opacity: 1;
}

/* POSITION SYSTEM */
.new-arrivals[data-position="top-left"] .na-overlay { justify-content:flex-start; align-items:flex-start; }
.new-arrivals[data-position="top-center"] .na-overlay { justify-content:center; align-items:flex-start; }
.new-arrivals[data-position="top-right"] .na-overlay { justify-content:flex-end; align-items:flex-start; }
.new-arrivals[data-position="center-left"] .na-overlay { justify-content:flex-start; align-items:center; }
.new-arrivals[data-position="center"] .na-overlay { justify-content:center; align-items:center; }
.new-arrivals[data-position="center-right"] .na-overlay { justify-content:flex-end; align-items:center; }
.new-arrivals[data-position="bottom-left"] .na-overlay { justify-content:flex-start; align-items:flex-end; }
.new-arrivals[data-position="bottom-center"] .na-overlay { justify-content:center; align-items:flex-end; }
.new-arrivals[data-position="bottom-right"] .na-overlay { justify-content:flex-end; align-items:flex-end; }

/* Mobile */
@media (max-width: 768px) {
  .na-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
document.querySelectorAll('.na-atc-form').forEach(form => {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const button = form.querySelector('button');
    const id = form.querySelector('input[name="id"]').value;

    button.disabled = true;
    button.innerText = "Adding...";

    try {
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, quantity: 1 })
      });

      // Refresh Dawn cart drawer
      document.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));

      button.innerText = "Added ✓";

      setTimeout(() => {
        button.innerText = "Add to Cart";
        button.disabled = false;
      }, 1200);

    } catch (err) {
      console.error(err);
      button.innerText = "Error";
    }
  });
});
</script>