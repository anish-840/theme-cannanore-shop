{% schema %}
{
  "name": "New Arrivals",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "New Arrivals" },

    { "type": "url", "id": "view_all_link", "label": "View All Collections Link" },
    { "type": "text", "id": "view_all_text", "label": "Button Text", "default": "View All Collections" },

    { "type": "color", "id": "header_color", "label": "Header Color", "default": "#000000" },

    { "type": "color", "id": "view_btn_bg", "label": "Button Background", "default": "#C17A5A" },
    { "type": "color", "id": "view_btn_text", "label": "Button Text Color", "default": "#ffffff" },
    { "type": "range", "id": "view_btn_radius", "label": "Button Radius", "min": 0, "max": 50, "step": 2, "default": 6 },
    { "type": "range", "id": "view_btn_border", "label": "Button Border Width", "min": 0, "max": 5, "step": 1, "default": 1 },

    { "type": "range", "id": "padding_top", "label": "Padding Top", "min": 0, "max": 100, "step": 5, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 100, "step": 5, "default": 40 },

    { "type": "product", "id": "featured_product", "label": "Featured Product" },

    { "type": "color", "id": "btn_bg", "label": "Add to Cart BG", "default": "#C17A5A" },
    { "type": "color", "id": "btn_text", "label": "Add to Cart Text", "default": "#ffffff" },
    { "type": "range", "id": "btn_radius", "label": "Add to Cart Radius", "min": 0, "max": 50, "step": 2, "default": 6 },

    {
      "type": "select",
      "id": "btn_position",
      "label": "Add to Cart Position",
      "default": "center",
      "options": [
        { "value": "top-left", "label": "Top Left" },
        { "value": "top-center", "label": "Top Center" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "center", "label": "Center" },
        { "value": "bottom-center", "label": "Bottom Center" }
      ]
    },

    { "type": "color", "id": "title_color", "label": "Product Title Color", "default": "#000000" },
    { "type": "color", "id": "price_color", "label": "Product Price Color", "default": "#666666" },
    { "type": "range", "id": "title_lines", "label": "Product Title Lines", "min": 1, "max": 4, "step": 1, "default": 2 },

    {
      "type": "range",
      "id": "info_spacing",
      "label": "Spacing Between Image & Product Info",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 10
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Grid Product",
      "limit": 4,
      "settings": [
        { "type": "product", "id": "product", "label": "Select Product" }
      ]
    }
  ],
  "presets": [{ "name": "New Arrivals" }]
}
{% endschema %}

<div 
  class="new-arrivals page-width"
  data-position="{{ section.settings.btn_position }}"
  style="
    --header-color: {{ section.settings.header_color }};
    --btn-bg: {{ section.settings.btn_bg }};
    --btn-text: {{ section.settings.btn_text }};
    --btn-radius: {{ section.settings.btn_radius }}px;

    --view-bg: {{ section.settings.view_btn_bg }};
    --view-text: {{ section.settings.view_btn_text }};
    --view-radius: {{ section.settings.view_btn_radius }}px;
    --view-border: {{ section.settings.view_btn_border }}px;

    --title-color: {{ section.settings.title_color }};
    --price-color: {{ section.settings.price_color }};
    --title-lines: {{ section.settings.title_lines }};

    --info-gap: {{ section.settings.info_spacing }}px;

    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>

  <!-- HEADER -->
  <div class="na-header">
    <h2>{{ section.settings.heading }}</h2>

    {% if section.settings.view_all_link %}
      <a href="{{ section.settings.view_all_link }}" class="na-view-btn">
        {{ section.settings.view_all_text }}
      </a>
    {% endif %}
  </div>

  <div class="na-grid">

    {% assign product = all_products[section.settings.featured_product] %}
    {% if product %}
    <div class="na-card">
      <div class="na-image-wrapper">
        <img src="{{ product.featured_image | image_url: width: 900 }}">

        <div class="na-overlay">
          <form class="na-atc-form">
            <input type="hidden" name="id" value="{{ product.variants.first.id }}">
            <button>Add to Cart</button>
          </form>
        </div>
      </div>

      <div class="na-info">
        <h3>{{ product.title }}</h3>
        <span>{{ product.price | money }}</span>
      </div>
    </div>
    {% endif %}

    <div class="na-products">
      {% for block in section.blocks %}
        {% assign p = all_products[block.settings.product] %}
        {% if p %}
        <div class="na-card">
          <div class="na-image-wrapper">
            <img src="{{ p.featured_image | image_url: width: 600 }}">

            <div class="na-overlay">
              <form class="na-atc-form">
                <input type="hidden" name="id" value="{{ p.variants.first.id }}">
                <button>Add to Cart</button>
              </form>
            </div>
          </div>

          <div class="na-info">
            <h4>{{ p.title }}</h4>
            <span>{{ p.price | money }}</span>
          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
.na-header {
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}

.na-header h2 {
  color: var(--header-color);
}

.na-view-btn {
  background: var(--view-bg);
  color: var(--view-text);
  border-radius: var(--view-radius);
  border: var(--view-border) solid var(--view-text);
  padding: 8px 16px;
  text-decoration:none;
}

.na-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:20px;
}

.na-products {
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:1fr 1fr;
  gap:15px;
}

.na-card {
  display:flex;
  flex-direction:column;
  height:100%;
}

.na-image-wrapper {
  position:relative;
  flex:1;
}

.na-image-wrapper img {
  width:100%;
  height:100%;
  object-fit:cover;
}

/* OVERLAY */
.na-overlay {
  position:absolute;
  inset:0;
  display:flex;
  padding:15px;
  background:rgba(0,0,0,0.25);
  opacity:0;
  transition:.3s;
}

.na-image-wrapper:hover .na-overlay {
  opacity:1;
}

/* POSITION SYSTEM */
.new-arrivals[data-position="top-left"] .na-overlay {justify-content:flex-start;align-items:flex-start;}
.new-arrivals[data-position="top-center"] .na-overlay {justify-content:center;align-items:flex-start;}
.new-arrivals[data-position="top-right"] .na-overlay {justify-content:flex-end;align-items:flex-start;}
.new-arrivals[data-position="center"] .na-overlay {justify-content:center;align-items:center;}
.new-arrivals[data-position="bottom-center"] .na-overlay {justify-content:center;align-items:flex-end;}

.na-overlay button {
  background:var(--btn-bg);
  color:var(--btn-text);
  border-radius:var(--btn-radius);
  border:none;
  padding:10px 18px;
}

/* 🔥 NEW GAP CONTROL */
.na-info {
  margin-top: var(--info-gap);
}

.na-info h3,
.na-info h4 {
  margin:0;
  font-size:16px;
  color:var(--title-color);

  display:-webkit-box;
  -webkit-line-clamp:var(--title-lines);
  -webkit-box-orient:vertical;
  overflow:hidden;
}

.na-info span {
  color:var(--price-color);
  font-size:14px;
}

@media(max-width:768px){
  .na-grid{grid-template-columns:1fr;}
}
</style>

<script>
document.querySelectorAll('.na-atc-form').forEach(form=>{
  form.addEventListener('submit',async(e)=>{
    e.preventDefault();

    const btn=form.querySelector('button');
    const id=form.querySelector('[name="id"]').value;

    btn.innerText="Adding...";
    btn.disabled=true;

    await fetch('/cart/add.js',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({id,quantity:1})
    });

    const cart=await fetch('/cart.js').then(r=>r.json());

    document.querySelectorAll('[data-cart-count], .cart-count-bubble span').forEach(el=>{
      el.textContent=cart.item_count;
    });

    btn.innerText="Added ✓";

    setTimeout(()=>{
      btn.innerText="Add to Cart";
      btn.disabled=false;
    },1000);
  });
});
</script>