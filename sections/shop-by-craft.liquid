{% schema %}
{
  "name": "Shop by Craft",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Craft"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2825"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Cards per row on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "craft_card",
      "name": "Craft Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Craft Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Craft",
      "blocks": [
        { "type": "craft_card" },
        { "type": "craft_card" },
        { "type": "craft_card" },
        { "type": "craft_card" }
      ]
    }
  ]
}
{% endschema %}

<div 
  class="shop-by-craft section-{{ section.id }}"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-size: {{ section.settings.heading_font_size }}px;
    --desktop-cols: {{ section.settings.desktop_columns }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="craft-cards-wrapper">
      <div class="craft-cards">
        {% for block in section.blocks %}
          <{% if block.settings.link %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="craft-card">
            <div class="craft-card__image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.text | escape }}"
                  loading="lazy"
                  class="craft-card__image"
                >
              {% else %}
                <div class="placeholder-svg craft-card__image">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}
            </div>
            {% if block.settings.text != blank %}
              <p class="craft-card__text">{{ block.settings.text }}</p>
            {% endif %}
          </{% if block.settings.link %}a{% else %}div{% endif %}>
        {% endfor %}
      </div>

      {% comment %} 
        --- Optional Carousel Controls for Mobile ---
        These are included structurally, but functional JavaScript for navigation is omitted in this section's pure CSS scroll-snap implementation for simplicity.
        Arrows are visually positioned. Indicators would require minimal JS to function correctly.
      {% endcomment %}
      <div class="carousel-controls mobile-only">
        <button class="carousel-arrow carousel-arrow--prev" aria-label="Previous">
          <svg viewBox="0 0 100 100"><path d="M 10,50 L 60,100 L 70,90 L 30,50 L 70,10 L 60,0 Z"></path></svg>
        </button>
        <div class="carousel-indicators">
          {% for block in section.blocks %}
            <span class="carousel-indicator{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
          {% endfor %}
        </div>
        <button class="carousel-arrow carousel-arrow--next" aria-label="Next">
          <svg viewBox="0 0 100 100"><path d="M 10,50 L 60,100 L 70,90 L 30,50 L 70,10 L 60,0 Z" transform="translate(100, 100) rotate(180) "></path></svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
.section-{{ section.id }} {
  background-color: var(--bg-color);
}

.section-{{ section.id }} .section-header__title {
  color: var(--heading-color);
  font-size: var(--heading-size);
  text-align: center;
  margin-bottom: 30px;
}

/* CARDS LAYOUT */
.craft-cards {
  display: grid;
  grid-template-columns: repeat(var(--desktop-cols), 1fr);
  gap: 20px;
}

.craft-card {
  text-decoration: none; /* remove link underlines */
  color: inherit; /* inherit text color */
  text-align: center;
  overflow: hidden; /* contain hover zoom */
  border-radius: 8px; /* subtle rounded corners */
  transition: transform 0.3s ease, box-shadow 0.3s ease; /* transition for hover animations */
}

/* HOVER ANIMATION */
.craft-card:hover {
  transform: translateY(-5px); /* subtle scale up or shift down */
  box-shadow: 0 4px 15px rgba(0,0,0,0.1); /* subtle shadow on hover */
}

.craft-card:hover .craft-card__image {
  transform: scale(1.05); /* zoom image on hover */
}

.craft-card__image-wrapper {
  overflow: hidden; /* crucial for zoom animation */
  border-radius: 8px 8px 0 0; /* top corners rounded */
}

.craft-card__image {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.3s ease; /* smoothly zoom the image */
}

.craft-card__text {
  margin: 15px 0 0;
  font-size: 16px;
  padding: 0 10px 15px; /* bottom padding with text */
}

/* CAROUSEL CONTROLS & MOBILE-ONLY VISIBILITY */
.carousel-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20px;
  position: relative; /* ensure controls are below/above carousel items */
  z-index: 10;
}

.carousel-arrow {
  background: none;
  border: none;
  cursor: pointer;
  padding: 10px;
  opacity: 0.7;
  transition: opacity 0.2s ease;
}

.carousel-arrow:hover {
  opacity: 1;
}

.carousel-arrow svg {
  width: 24px;
  height: 24px;
  fill: currentColor;
}

.carousel-indicators {
  display: flex;
  gap: 8px;
  margin: 0 15px;
}

.carousel-indicator {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background-color: #e0e0e0;
  cursor: pointer;
  transition: background-color 0.2s ease;
}

.carousel-indicator.active {
  background-color: currentColor; /* active dot same color as text/heading */
}

/* MOBILE MEDIA QUERY */
@media (max-width: 768px) {
  .section-{{ section.id }} .section-header__title {
    margin-bottom: 20px;
  }

  .craft-cards {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory; /* enables CSS scroll-snap carousel effect */
    gap: 15px;
    padding-bottom: 10px; /* some spacing for controls */
    -webkit-overflow-scrolling: touch; /* smooth scrolling on iOS */
    margin-left: -20px; /* pull container out to edge */
    margin-right: -20px;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* each card occupies most of the view on mobile */
  .craft-card {
    flex: 0 0 calc(100% - 30px); /* 1 card per view (leaving some space for gap) */
    scroll-snap-align: center; /* snap card to center */
    border-radius: 0; /* optional, reset radius for edge-to-edge feel */
    box-shadow: none; /* optional, reduce shadows on mobile for performance */
  }

  .craft-card:hover {
    transform: none; /* disable shift down hover on mobile (tap interaction) */
    box-shadow: none;
  }
  
  /* optionally keep image zoom but slightly reduce its scale */
  .craft-card:hover .craft-card__image {
     transform: scale(1.03); 
  }

  .craft-card__text {
    font-size: 14px;
    padding: 0 5px 10px;
  }

  .mobile-only {
    display: flex !important; /* show carousel controls */
  }
  
  .carousel-arrow--prev {
    position: absolute;
    left: 10px;
  }

  .carousel-arrow--next {
    position: absolute;
    right: 10px;
  }
}
</style>