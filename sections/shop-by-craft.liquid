{% schema %}
{
  "name": "Shop by Craft",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Craft"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#2C2825"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Cards per row on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "craft_card",
      "name": "Craft Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Craft Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Craft",
      "blocks": [
        { "type": "craft_card" },
        { "type": "craft_card" },
        { "type": "craft_card" },
        { "type": "craft_card" }
      ]
    }
  ]
}
{% endschema %}

<div 
  class="shop-by-craft section-{{ section.id }}"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --heading-color: {{ section.settings.heading_color }};
    --heading-size: {{ section.settings.heading_font_size }}px;
    --desktop-cols: {{ section.settings.desktop_columns }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="section-header__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="craft-cards-wrapper">
      <div class="craft-cards">
        {% for block in section.blocks %}
          <{% if block.settings.link %}a href="{{ block.settings.link }}"{% else %}div{% endif %} class="craft-card" data-index="{{ forloop.index0 }}">
            <div class="craft-card__image-wrapper">
              {% if block.settings.image %}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}"
                  alt="{{ block.settings.text | escape }}"
                  loading="lazy"
                  class="craft-card__image"
                >
              {% else %}
                <div class="placeholder-svg craft-card__image">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}
            </div>
            {% if block.settings.text != blank %}
              <p class="craft-card__text">{{ block.settings.text }}</p>
            {% endif %}
          </{% if block.settings.link %}a{% else %}div{% endif %}>
        {% endfor %}
      </div>
      
      <div class="carousel-controls">
        <button class="carousel-arrow carousel-arrow--prev" aria-label="Previous">
          <svg viewBox="0 0 24 24" width="24" height="24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
        </button>
        <div class="carousel-indicators">
          {% for block in section.blocks %}
            <span class="carousel-indicator{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index0 }}"></span>
          {% endfor %}
        </div>
        <button class="carousel-arrow carousel-arrow--next" aria-label="Next">
          <svg viewBox="0 0 24 24" width="24" height="24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
        </button>
      </div>

    </div>
  </div>
</div>

<style>
.section-{{ section.id }} {
  background-color: var(--bg-color);
}

.section-{{ section.id }} .section-header__title {
  color: var(--heading-color);
  font-size: var(--heading-size);
  text-align: center;
  margin-bottom: 30px;
}

/* CARDS LAYOUT */
.craft-cards-wrapper {
  position: relative;
}

.craft-cards {
  display: grid;
  grid-template-columns: repeat(var(--desktop-cols), 1fr);
  gap: 20px;
}

.craft-card {
  text-decoration: none;
  color: inherit;
  text-align: center;
  overflow: hidden;
  border-radius: 8px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* HOVER ANIMATION */
.craft-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 4px 15px rgba(0,0,0,0.1);
}

.craft-card:hover .craft-card__image {
  transform: scale(1.05);
}

.craft-card__image-wrapper {
  overflow: hidden;
  border-radius: 8px 8px 0 0;
}

.craft-card__image {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.3s ease;
}

.craft-card__text {
  margin: 15px 0 0;
  font-size: 16px;
  padding: 0 10px 15px;
}

/* CAROUSEL CONTROLS (Hidden by default on desktop) */
.carousel-controls {
  display: none;
}

/* MOBILE MEDIA QUERY */
@media (max-width: 768px) {
  .section-{{ section.id }} .section-header__title {
    margin-bottom: 20px;
  }

  .craft-cards {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 15px;
    padding-bottom: 10px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  .craft-cards::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .craft-card {
    flex: 0 0 85%; 
    scroll-snap-align: center;
    border-radius: 8px; 
    box-shadow: none; 
  }

  .craft-card:hover {
    transform: none; 
    box-shadow: none;
  }
  
  .craft-card:hover .craft-card__image {
     transform: scale(1.03); 
  }

  .craft-card__text {
    font-size: 14px;
    padding: 0 5px 10px;
  }

  /* SHOW CAROUSEL CONTROLS ON MOBILE */
  .carousel-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    margin-top: 15px;
  }

  .carousel-arrow {
    background: none;
    border: none;
    padding: 5px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--heading-color);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .carousel-arrow:hover {
    opacity: 1;
  }

  .carousel-arrow svg {
    fill: currentColor;
  }

  .carousel-indicators {
    display: flex;
    gap: 8px;
  }

  .carousel-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #d1d1d1;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .carousel-indicator.active {
    background-color: var(--heading-color);
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;

    const container = section.querySelector('.craft-cards');
    const prevBtn = section.querySelector('.carousel-arrow--prev');
    const nextBtn = section.querySelector('.carousel-arrow--next');
    const indicators = section.querySelectorAll('.carousel-indicator');
    const cards = section.querySelectorAll('.craft-card');

    if (!container || cards.length === 0) return;

    // Calculate scroll width for one card
    const getScrollAmount = () => {
      // Includes the card width plus the flex gap (15px)
      return cards[0].offsetWidth + 15; 
    };

    // Button Clicks
    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        container.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        container.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
    }

    // Dot Indicator Clicks
    indicators.forEach((indicator, index) => {
      indicator.addEventListener('click', () => {
        container.scrollTo({ left: index * getScrollAmount(), behavior: 'smooth' });
      });
    });

    // Update active dot on swipe/scroll
    container.addEventListener('scroll', () => {
      const scrollPosition = container.scrollLeft;
      // Determine which card is currently taking up the majority of the view
      const activeIndex = Math.round(scrollPosition / getScrollAmount());

      indicators.forEach((indicator, index) => {
        if (index === activeIndex) {
          indicator.classList.add('active');
        } else {
          indicator.classList.remove('active');
        }
      });
    });
  });
</script>