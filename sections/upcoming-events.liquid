{% schema %}
{
  "name": "Upcoming Events",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Upcoming Events"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Card Style"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "card_text",
      "label": "Card Text Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Events per row (Desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "header",
      "content": "Add to Calendar Button"
    },
    {
      "type": "color",
      "id": "cal_btn_bg",
      "label": "Background Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "cal_btn_text",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "cal_btn_border",
      "label": "Border Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "cal_btn_border_width",
      "label": "Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "cal_btn_border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 6,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Get Directions Button"
    },
    {
      "type": "color",
      "id": "dir_btn_bg",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "dir_btn_text",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "dir_btn_border",
      "label": "Border Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "dir_btn_border_width",
      "label": "Border Width",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "dir_btn_border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 6,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "Event",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Event Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Event Title",
          "default": "Community Meetup"
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "October 24, 2026"
        },
        {
          "type": "text",
          "id": "time",
          "label": "Time",
          "default": "10:00 AM - 2:00 PM"
        },
        {
          "type": "text",
          "id": "location_name",
          "label": "Location Name",
          "default": "Main Flagship Store"
        },
        {
          "type": "textarea",
          "id": "address",
          "label": "Address",
          "default": "123 Commerce St, New York, NY 10001"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Join us for an exclusive look at our new collection, featuring special guests and refreshments."
        },
        {
          "type": "url",
          "id": "directions_link",
          "label": "Get Directions Link",
          "info": "Link to Google Maps or Apple Maps. (Leave blank to hide)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upcoming Events",
      "blocks": [
        { "type": "event" },
        { "type": "event" },
        { "type": "event" }
      ]
    }
  ]
}
{% endschema %}

<div 
  class="events-section section-{{ section.id }}"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --card-bg: {{ section.settings.card_bg }};
    --card-text: {{ section.settings.card_text }};
    --card-radius: {{ section.settings.card_border_radius }}px;
    
    --cal-btn-bg: {{ section.settings.cal_btn_bg }};
    --cal-btn-text: {{ section.settings.cal_btn_text }};
    --cal-btn-border: {{ section.settings.cal_btn_border }};
    --cal-btn-border-width: {{ section.settings.cal_btn_border_width }}px;
    --cal-btn-radius: {{ section.settings.cal_btn_border_radius }}px;
    
    --dir-btn-bg: {{ section.settings.dir_btn_bg }};
    --dir-btn-text: {{ section.settings.dir_btn_text }};
    --dir-btn-border: {{ section.settings.dir_btn_border }};
    --dir-btn-border-width: {{ section.settings.dir_btn_border_width }}px;
    --dir-btn-radius: {{ section.settings.dir_btn_border_radius }}px;

    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --cols-desktop: {{ section.settings.columns_desktop }};
  "
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="events-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="events-grid">
      {% for block in section.blocks %}
        <div class="event-card" {{ block.shopify_attributes }}>
          
          {% if block.settings.image %}
            <div class="event-image-wrapper">
              <img 
                src="{{ block.settings.image | image_url: width: 600 }}" 
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                class="event-image"
              >
            </div>
          {% endif %}

          <div class="event-content">
            {% if block.settings.title != blank %}
              <h3 class="event-title">{{ block.settings.title }}</h3>
            {% endif %}

            <div class="event-details">
              {% if block.settings.date != blank %}
                <div class="event-detail-item">
                  <svg viewBox="0 0 24 24" width="18" height="18" class="event-icon"><path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2z"/></svg>
                  <span>{{ block.settings.date }}</span>
                </div>
              {% endif %}
              
              {% if block.settings.time != blank %}
                <div class="event-detail-item">
                  <svg viewBox="0 0 24 24" width="18" height="18" class="event-icon"><path fill="currentColor" d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
                  <span>{{ block.settings.time }}</span>
                </div>
              {% endif %}

              {% if block.settings.location_name != blank or block.settings.address != blank %}
                <div class="event-detail-item event-detail-location">
                  <svg viewBox="0 0 24 24" width="18" height="18" class="event-icon"><path fill="currentColor" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                  <div>
                    {% if block.settings.location_name != blank %}
                      <strong>{{ block.settings.location_name }}</strong><br>
                    {% endif %}
                    {% if block.settings.address != blank %}
                      <span class="event-address">{{ block.settings.address | newline_to_br }}</span>
                    {% endif %}
                  </div>
                </div>
              {% endif %}
            </div>

            {% if block.settings.description != blank %}
              <div class="event-description">
                {{ block.settings.description | newline_to_br }}
              </div>
            {% endif %}
          </div>

          <div class="event-actions">
            <button 
              type="button" 
              class="event-btn btn-calendar js-add-to-calendar"
              data-title="{{ block.settings.title | escape }}"
              data-date="{{ block.settings.date | escape }}"
              data-time="{{ block.settings.time | escape }}"
              data-location="{{ block.settings.location_name | escape }} {{ block.settings.address | escape }}"
              data-description="{{ block.settings.description | strip_html | escape }}"
            >
              <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20a2 2 0 002 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm0-12H5V6h14v2zm-7 5h5v5h-5z"/></svg>
              Add to Calendar
            </button>
            
            {% if block.settings.directions_link != blank %}
              <a href="{{ block.settings.directions_link }}" target="_blank" class="event-btn btn-directions">
                <svg viewBox="0 0 24 24" width="16" height="16"><path fill="currentColor" d="M21.71 11.29l-9-9c-.39-.39-1.02-.39-1.41 0l-9 9c-.39.39-.39 1.02 0 1.41l9 9c.39.39 1.02.39 1.41 0l9-9c.39-.38.39-1.01 0-1.41zM14 14.5V12h-4v3H8v-4c0-.55.45-1 1-1h5V7.5l3.5 3.5-3.5 3.5z"/></svg>
                Get Directions
              </a>
            {% endif %}
          </div>

        </div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
.section-{{ section.id }} {
  background-color: var(--bg-color);
  padding-top: var(--pt);
  padding-bottom: var(--pb);
}

.events-heading {
  text-align: center;
  color: var(--text-color);
  font-size: 32px;
  margin-bottom: 40px;
}

.events-grid {
  display: grid;
  grid-template-columns: repeat(var(--cols-desktop), 1fr);
  gap: 30px;
}

/* CARD STRUCTURE */
.event-card {
  background-color: var(--card-bg);
  color: var(--card-text);
  border-radius: var(--card-radius);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.event-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(0,0,0,0.1);
}

.event-image-wrapper {
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
}

.event-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.event-content {
  padding: 24px;
  flex-grow: 1; /* Pushes footer to the bottom */
  display: flex;
  flex-direction: column;
}

.event-title {
  font-size: 22px;
  margin: 0 0 16px 0;
  line-height: 1.3;
}

.event-details {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 20px;
}

.event-detail-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 15px;
  line-height: 1.4;
  opacity: 0.9;
}

.event-icon {
  margin-top: 2px;
  flex-shrink: 0;
  opacity: 0.7;
}

.event-address {
  font-size: 14px;
  opacity: 0.8;
}

.event-description {
  font-size: 15px;
  line-height: 1.6;
  opacity: 0.8;
  margin-top: auto; /* Push down below details */
  padding-top: 15px;
  border-top: 1px solid rgba(0,0,0,0.05);
}

/* ACTIONS / BUTTONS */
.event-actions {
  padding: 0 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.event-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 20px;
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  transition: opacity 0.3s ease;
  width: 100%;
  box-sizing: border-box;
  cursor: pointer;
  font-family: inherit;
}

.event-btn:hover {
  opacity: 0.85;
}

.btn-calendar {
  background-color: var(--cal-btn-bg);
  color: var(--cal-btn-text);
  border: var(--cal-btn-border-width) solid var(--cal-btn-border);
  border-radius: var(--cal-btn-radius);
}

.btn-directions {
  background-color: var(--dir-btn-bg);
  color: var(--dir-btn-text);
  border: var(--dir-btn-border-width) solid var(--dir-btn-border);
  border-radius: var(--dir-btn-radius);
}

/* MOBILE RESPONSIVENESS */
@media (max-width: 990px) {
  .events-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .events-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  
  .events-heading {
    font-size: 26px;
    margin-bottom: 24px;
  }
  
  .event-actions {
    flex-direction: column;
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;

    const calendarBtns = section.querySelectorAll('.js-add-to-calendar');

    calendarBtns.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.preventDefault();

        const title = this.dataset.title || 'Event';
        const dateStr = this.dataset.date || '';
        const timeStr = this.dataset.time || '';
        const location = this.dataset.location || '';
        const description = this.dataset.description || '';

        // Attempt to parse the date and time provided
        let startDate = new Date(dateStr);
        let endDate = new Date(dateStr);

        // Basic parsing for time text (e.g. "10:00 AM - 2:00 PM")
        const timeMatch = timeStr.match(/(\d{1,2}):(\d{2})\s*(AM|PM)?/i);
        if (timeMatch && !isNaN(startDate.getTime())) {
          let hours = parseInt(timeMatch[1], 10);
          let mins = parseInt(timeMatch[2], 10);
          const ampm = timeMatch[3] ? timeMatch[3].toUpperCase() : '';

          if (ampm === 'PM' && hours < 12) hours += 12;
          if (ampm === 'AM' && hours === 12) hours = 0;

          startDate.setHours(hours, mins, 0);
          
          // Default duration of 1 hour if end time isn't strictly parsed
          endDate.setHours(hours + 1, mins, 0); 
        }

        // Format dates to ICS standard: YYYYMMDDTHHMMSSZ
        const formatDateIcs = (date) => {
          if (isNaN(date.getTime())) return null;
          return date.toISOString().replace(/-|:|\.\d+/g, '');
        };

        const dtStart = formatDateIcs(startDate);
        const dtEnd = formatDateIcs(endDate);

        // Build the .ics file content
        let icsData = `BEGIN:VCALENDAR\nVERSION:2.0\nBEGIN:VEVENT\nSUMMARY:${title}\n`;
        
        if (dtStart && dtEnd) {
          icsData += `DTSTART:${dtStart}\nDTEND:${dtEnd}\n`;
        } else {
          // Fallback if date completely failed to parse (creates an all day event today)
          const today = formatDateIcs(new Date()).substring(0, 8);
          icsData += `DTSTART;VALUE=DATE:${today}\n`;
        }

        icsData += `LOCATION:${location}\nDESCRIPTION:${description}\nEND:VEVENT\nEND:VCALENDAR`;

        // Create a downloadable Blob
        const blob = new Blob([icsData], { type: 'text/calendar;charset=utf-8' });
        const url = window.URL.createObjectURL(blob);
        
        const link = document.createElement('a');
        link.href = url;
        link.download = `${title.replace(/[^a-z0-9]/gi, '_').toLowerCase()}.ics`;
        document.body.appendChild(link);
        link.click();
        
        // Cleanup
        document.body.removeChild(link);
        window.URL.revokeObjectURL(url);
      });
    });
  });
</script>