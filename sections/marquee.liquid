{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing Between Items",
      "min": 20,
      "max": 120,
      "step": 10,
      "default": 60
    },
    {
      "type": "text",
      "id": "divider",
      "label": "Divider Symbol",
      "default": "•"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#2C2825"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#C17A5A"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#C17A5A"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Your text here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee"
    }
  ]
}
{% endschema %}

<div 
  class="marquee-wrapper {% if section.settings.pause_on_hover %}pause-on-hover{% endif %}"
  style="
    --bg: {{ section.settings.bg_color }};
    --text: {{ section.settings.text_color }};
    --divider: {{ section.settings.divider_color }};
    --speed: {{ section.settings.speed }}s;
    --spacing: {{ section.settings.spacing }}px;
  "
>
  <div class="marquee-track">

    {% capture marquee_content %}
      {% for block in section.blocks %}
        <span class="marquee-item">
          {{ block.settings.text }}
        </span>

        <!-- ALWAYS add divider (even after last for loop continuity) -->
        <span 
          class="marquee-divider"
          data-divider="{{ section.settings.divider }}"
        ></span>
      {% endfor %}
    {% endcapture %}

    <!-- Repeat content multiple times for large screens -->
    {% for i in (1..6) %}
      <div class="marquee-content">
        {{ marquee_content }}
      </div>
    {% endfor %}

  </div>
</div>

<style>
.marquee-wrapper {
  overflow: hidden;
  width: 100%;
  background: var(--bg);
}

.marquee-track {
  display: flex;
  width: max-content;
  animation: marquee-scroll linear infinite;
  animation-duration: var(--speed);
}

.marquee-content {
  display: flex;
  align-items: center;
}

.marquee-item {
  margin-right: var(--spacing);
  white-space: nowrap;
  font-size: 16px;
  color: var(--text);
}

/* Divider */
.marquee-divider {
  margin-right: var(--spacing);
  color: var(--divider);
  opacity: 0.7;
}

.marquee-divider::before {
  content: attr(data-divider);
}

/* Pause on hover */
.pause-on-hover:hover .marquee-track {
  animation-play-state: paused;
}

/* TRUE continuous loop */
@keyframes marquee-scroll {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-16.66%);
  }
}
</style>