{% schema %}
{
  "name": "Instagram Feed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Us on Instagram"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Follow Us"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Instagram Profile Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Columns on Desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video (Optional)",
          "info": "If provided, this will play automatically instead of the image."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram Post Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Feed",
      "blocks": [
        { "type": "post" },
        { "type": "post" },
        { "type": "post" },
        { "type": "post" }
      ]
    }
  ]
}
{% endschema %}

{% assign hide_desktop_nav = false %}
{% if section.blocks.size <= section.settings.desktop_columns %}
  {% assign hide_desktop_nav = true %}
{% endif %}

<div 
  class="instagram-section section-{{ section.id }}"
  style="
    --bg-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --desktop-cols: {{ section.settings.desktop_columns }};
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    
    <div class="instagram-header-wrapper">
      <div class="instagram-header">
        <svg class="instagram-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
        </svg>
        {% if section.settings.heading != blank %}
          <h2 class="instagram-title">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      
      {% if section.settings.button_text != blank and section.settings.button_link != blank %}
        <a href="{{ section.settings.button_link }}" target="_blank" class="instagram-follow-btn">
          {{ section.settings.button_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="M12 5l7 7-7 7"></path>
          </svg>
        </a>
      {% endif %}
    </div>

    <div class="instagram-carousel-wrapper {% if hide_desktop_nav %}hide-desktop-arrows{% endif %}">
      
      <button class="insta-nav insta-nav--prev" aria-label="Previous">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6 1.41-1.41z"/></svg>
      </button>

      <div class="instagram-carousel">
        {% for block in section.blocks %}
          <div class="instagram-slide" {{ block.shopify_attributes }}>
            <{% if block.settings.link %}a href="{{ block.settings.link }}" target="_blank"{% else %}div{% endif %} class="instagram-media-wrapper">
              
              {% if block.settings.video != blank %}
                {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'instagram-media' }}
              {% elsif block.settings.image != blank %}
                <img 
                  src="{{ block.settings.image | image_url: width: 600 }}" 
                  alt="Instagram Post" 
                  loading="lazy" 
                  class="instagram-media"
                >
              {% else %}
                <div class="placeholder-svg instagram-media">{{ 'image' | placeholder_svg_tag }}</div>
              {% endif %}

              <div class="instagram-overlay">
                <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>

            </{% if block.settings.link %}a{% else %}div{% endif %}>
          </div>
        {% endfor %}
      </div>

      <button class="insta-nav insta-nav--next" aria-label="Next">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
      </button>

    </div>

    <div class="instagram-indicators">
      {% for block in section.blocks %}
        <div class="insta-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}"></div>
      {% endfor %}
    </div>

  </div>
</div>

<style>
.section-{{ section.id }} {
  background-color: var(--bg-color);
  padding-top: var(--pt);
  padding-bottom: var(--pb);
  overflow: hidden;
}

/* HEADER WRAPPER */
.instagram-header-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40px;
  gap: 16px;
}

.instagram-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  color: var(--text-color);
}

.instagram-icon {
  width: 32px;
  height: 32px;
}

.instagram-title {
  margin: 0;
  font-size: 28px;
  color: var(--text-color);
  line-height: 1.2;
}

/* BUTTON */
.instagram-follow-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 12px 28px;
  background-color: var(--text-color);
  color: var(--bg-color);
  text-decoration: none;
  font-size: 14px;
  font-weight: 600;
  letter-spacing: 0.5px;
  border-radius: 30px;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.3s ease;
}

.instagram-follow-btn svg {
  transition: transform 0.3s ease;
}

.instagram-follow-btn:hover {
  transform: translateY(-2px);
  opacity: 0.95;
}

.instagram-follow-btn:hover svg {
  transform: translateX(3px);
}

/* CAROUSEL WRAPPER */
.instagram-carousel-wrapper {
  position: relative;
  z-index: 1; /* Added to establish stacking context */
  display: flex;
  align-items: center;
}

.instagram-carousel {
  display: flex;
  align-items: center;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  gap: 15px;
  padding-bottom: 15px;
  scrollbar-width: none;
  -ms-overflow-style: none;
  -webkit-overflow-scrolling: touch;
  width: 100%;
}

.instagram-carousel::-webkit-scrollbar {
  display: none;
}

/* SLIDES */
.instagram-slide {
  flex: 0 0 calc((100% - ((var(--desktop-cols) - 1) * 15px)) / var(--desktop-cols));
  scroll-snap-align: start;
}

.instagram-media-wrapper {
  display: block;
  position: relative;
  width: 100%;
  overflow: hidden;
  border-radius: 8px;
  background: #f4f4f4;
}

.instagram-media {
  width: 100%;
  height: auto;
  display: block;
  transition: transform 0.4s ease;
}

/* HOVER OVERLAY */
.instagram-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}

.instagram-media-wrapper:hover .instagram-overlay {
  opacity: 1;
}

.instagram-media-wrapper:hover .instagram-media {
  transform: scale(1.05);
}

/* NAVIGATION ARROWS */
.insta-nav {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 1; /* Lowered from 10 to 1 */
  background: #fff;
  color: #121212;
  border: 1px solid #e0e0e0;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: background-color 0.2s, opacity 0.2s;
  opacity: 0;
}

.instagram-carousel-wrapper:hover .insta-nav {
  opacity: 1;
}

.insta-nav:hover {
  background: #f4f4f4;
}

.insta-nav--prev { left: -20px; }
.insta-nav--next { right: -20px; }

/* HIDE DESKTOP ARROWS IF 4 OR FEWER CARDS */
@media (min-width: 769px) {
  .hide-desktop-arrows .insta-nav {
    display: none !important;
  }
}

/* INDICATORS (HIDDEN ON DESKTOP) */
.instagram-indicators {
  display: none;
}

/* MOBILE RESPONSIVE */
@media (max-width: 768px) {
  .instagram-header-wrapper {
    margin-bottom: 30px;
  }
  
  .instagram-title {
    font-size: 24px;
  }
  
  .instagram-icon {
    width: 28px;
    height: 28px;
  }

  /* Reduce width to 82% to proportionally decrease height, add side padding to center */
  .instagram-carousel {
    padding: 0 9% 15px 9%; 
  }

  .instagram-slide {
    flex: 0 0 82%; 
    scroll-snap-align: center;
  }
  
  .instagram-media-wrapper:hover .instagram-media {
    transform: none;
  }
  
  /* Make arrows visible, but slightly smaller and tucked in */
  .insta-nav {
    display: flex !important;
    width: 32px;
    height: 32px;
    opacity: 0.8;
  }
  
  .insta-nav--prev { left: 0px; }
  .insta-nav--next { right: 0px; }

  /* Show indicators on mobile */
  .instagram-indicators {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 10px;
  }

  .insta-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0,0,0,0.15);
    transition: background 0.3s ease;
  }

  .insta-dot.active {
    background: var(--text-color);
  }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.section-{{ section.id }}');
    if (!section) return;

    const carousel = section.querySelector('.instagram-carousel');
    const prevBtn = section.querySelector('.insta-nav--prev');
    const nextBtn = section.querySelector('.insta-nav--next');
    const dots = section.querySelectorAll('.insta-dot');

    if (!carousel) return;

    const getScrollAmount = () => {
      const slide = carousel.querySelector('.instagram-slide');
      return slide.offsetWidth + 15;
    };

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        carousel.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });
    }

    // Mobile Dots Highlight Logic
    if (dots.length > 0) {
      carousel.addEventListener('scroll', () => {
        // Find the center of the visible carousel
        const carouselCenter = carousel.scrollLeft + (carousel.offsetWidth / 2);
        const slides = carousel.querySelectorAll('.instagram-slide');
        
        let activeIndex = 0;
        let minDistance = Infinity;

        slides.forEach((slide, index) => {
          // Calculate center of each slide
          const slideCenter = slide.offsetLeft + (slide.offsetWidth / 2);
          const distance = Math.abs(carouselCenter - slideCenter);
          
          if (distance < minDistance) {
            minDistance = distance;
            activeIndex = index;
          }
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === activeIndex);
        });
      });

      // Allow tapping dots to scroll
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const slideWidth = carousel.querySelector('.instagram-slide').offsetWidth + 15;
          carousel.scrollTo({ left: slideWidth * index, behavior: 'smooth' });
        });
      });
    }
  });
</script>