          "value": "px",
          "label": "Pixels (px)"
        },
        {
          "value": "rem",
          "label": "Relative (rem)"
        }
      ],
      "default": "px"
    },
    {
      "type": "range",
      "id": "font_size_px",
      "label": "Font size (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_rem",
      "label": "Font size (rem)",
      "min": 0.5,
      "max": 2,
      "step": 0.1,
      "unit": "rem",
      "default": 0.9
