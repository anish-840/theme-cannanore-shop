      "type": "header",
      "content": "Mobile typography"
    },
    {
      "type": "select",
      "id": "mobile_font_unit",
      "label": "Mobile font size unit",
      "options": [
        {
          "value": "px",
          "label": "Pixels (px)"
        },
        {
          "value": "rem",
          "label": "Relative (rem)"
        }
      ],
      "default": "px"
    },
    {
      "type": "range",
      "id": "mobile_font_size_px",
