{% doc %}
  @prompt
    Create a breadcrumb navigation component that appears only on product pages with the following features: configurable text font size (px/rem options), text color picker, customizable breadcrumb separator (/, >, →), maximum number of lines setting (default 1), ellipsis truncation with configurable character limit, positioned above product title, fully responsive for mobile and desktop, and adjustable spacing/margins for clean layout integration. Include theme editor settings for all customization options., Its not showing the breadcrumps properly and add | separator. Fix the breadcrump, Add settings for the text active page and normal text colors, Add a setting for horizontal and vertical padding, Add different padding and font size settings for mobile and desktop view, Add separate settings for maximum lines, character limit per items and ellipsis switch for desktop and mobile separate, Increase the max Character limit per item in desktop, Add a setting to change the separator color

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-breadcrumb-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.bottom_spacing }}px;
    margin-top: {{ block.settings.top_spacing }}px;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    font-size: {% if block.settings.font_unit == 'rem' %}{{ block.settings.font_size_rem }}rem{% else %}{{ block.settings.font_size_px }}px{% endif %};
    color: {{ block.settings.text_color }};
    line-height: 1.4;
  }

  .ai-breadcrumb-nav-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
    {% if block.settings.max_lines == 1 %}
      white-space: nowrap;
      overflow: hidden;
    {% else %}
      flex-wrap: wrap;
    {% endif %}
  }

  .ai-breadcrumb-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    {% if block.settings.max_lines == 1 %}
      flex-shrink: 1;
      min-width: 0;
    {% endif %}
  }

  .ai-breadcrumb-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s ease;
    {% if block.settings.max_lines == 1 and block.settings.enable_ellipsis %}
      max-width: {{ block.settings.char_limit }}ch;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      display: block;
    {% endif %}
  }

  .ai-breadcrumb-link-{{ ai_gen_id }}:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .ai-breadcrumb-current-{{ ai_gen_id }} {
    color: {{ block.settings.active_color }};
    font-weight: 500;
    {% if block.settings.max_lines == 1 and block.settings.enable_ellipsis %}
      max-width: {{ block.settings.char_limit }}ch;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      display: block;
    {% endif %}
  }

  .ai-breadcrumb-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    opacity: 0.6;
    user-select: none;
    flex-shrink: 0;
    font-size: 0.9em;
  }

  {% if block.settings.max_lines > 1 %}
    .ai-breadcrumb-nav-{{ ai_gen_id }} {
      display: -webkit-box;
      -webkit-line-clamp: {{ block.settings.max_lines }};
      -webkit-box-orient: vertical;
      overflow: hidden;
      word-break: break-word;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-breadcrumb-{{ ai_gen_id }} {
      font-size: {% if block.settings.mobile_font_unit == 'rem' %}{{ block.settings.mobile_font_size_rem }}rem{% else %}{{ block.settings.mobile_font_size_px }}px{% endif %};
      margin-bottom: {{ block.settings.mobile_bottom_spacing }}px;
      margin-top: {{ block.settings.mobile_top_spacing }}px;
      padding: {{ block.settings.mobile_vertical_padding }}px {{ block.settings.mobile_horizontal_padding }}px;
    }

    .ai-breadcrumb-nav-{{ ai_gen_id }} {
      gap: 6px;
      {% if block.settings.mobile_max_lines == 1 %}
        white-space: nowrap;
        overflow: hidden;
      {% else %}
        flex-wrap: wrap;
      {% endif %}
    }

    {% if block.settings.mobile_max_lines > 1 %}
      .ai-breadcrumb-nav-{{ ai_gen_id }} {
        display: -webkit-box;
        -webkit-line-clamp: {{ block.settings.mobile_max_lines }};
        -webkit-box-orient: vertical;
        overflow: hidden;
        word-break: break-word;
      }
    {% endif %}

    .ai-breadcrumb-link-{{ ai_gen_id }} {
      {% if block.settings.mobile_max_lines == 1 and block.settings.mobile_enable_ellipsis %}
        max-width: {{ block.settings.mobile_char_limit }}ch;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
      {% else %}
        max-width: none;
        overflow: visible;
        text-overflow: unset;
        white-space: normal;
      {% endif %}
    }

    .ai-breadcrumb-current-{{ ai_gen_id }} {
      {% if block.settings.mobile_max_lines == 1 and block.settings.mobile_enable_ellipsis %}
        max-width: {{ block.settings.mobile_char_limit }}ch;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        display: block;
      {% else %}
        max-width: none;
        overflow: visible;
        text-overflow: unset;
        white-space: normal;
      {% endif %}
    }
  }
{% endstyle %}

{% if template contains 'product' and product %}
  <nav
    class="ai-breadcrumb-{{ ai_gen_id }}"
    aria-label="Breadcrumb navigation"
    {{ block.shopify_attributes }}
  >
    <ol class="ai-breadcrumb-nav-{{ ai_gen_id }}"><li class="ai-breadcrumb-item-{{ ai_gen_id }}">
        <a href="{{ routes.root_url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">
          {{ block.settings.home_text }}
        </a>
      </li>

      {% if product.collections.size > 0 %}
        <li class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">
          {% case block.settings.separator %}
            {% when 'slash' %}
              /
            {% when 'chevron' %}
              >
            {% when 'arrow' %}
              →
            {% when 'pipe' %}
              |
          {% endcase %}
        </li>

        <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <a href="{{ product.collections.first.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">
            {{ product.collections.first.title }}
          </a>
        </li>
      {% endif %}

      <li class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">
        {% case block.settings.separator %}
          {% when 'slash' %}
            /
          {% when 'chevron' %}
            >
          {% when 'arrow' %}
            →
          {% when 'pipe' %}
            |
        {% endcase %}
      </li>

      <li class="ai-breadcrumb-item-{{ ai_gen_id }}">
        <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">
          {{ product.title }}
        </span>
      </li>
    </ol>
  </nav>
{% endif %}

{% schema %}
{
  "name": "Product breadcrumb",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "select",
      "id": "separator",
      "label": "Separator",
      "options": [
        {
          "value": "slash",
          "label": "/"
        },
        {
          "value": "chevron",
          "label": ">"
        },
        {
          "value": "arrow",
          "label": "→"
        },
        {
          "value": "pipe",
          "label": "|"
        }
      ],
      "default": "chevron"
    },
    {
      "type": "header",
      "content": "Desktop typography"
    },
    {
      "type": "select",
      "id": "font_unit",
      "label": "Font size unit",
      "options": [
