{% doc %}
  @prompt
    Create a customizable text section that displays multiple text items directly below the header with the following features:
    
    **Section Placement & Behavior:**
    - Position immediately below the main header
    - Toggle option for sticky/fixed positioning below header or normal scrolling behavior
    - Desktop visibility by default with optional mobile visibility toggle
    
    **Text Items Management:**
    - Support for 10 text items that can be added/removed
    - Each text item includes: customizable text content, configurable font size/color/weight/hover color/font family, optional linking to collections/products/pages/external URLs
    - Layout options to arrange text items horizontally in a row or vertically in a column
    - Text alignment controls (left, center, right)
    - Optional separators between items (pipe | or bullet • symbols)
    
    **Styling & Customization:**
    - Configurable horizontal padding (left/right spacing)
    - Configurable vertical padding (top/bottom spacing with separate top and bottom controls)
    - Background color or background image options for the section
    - Theme selection option for predefined styling
    - Responsive design that works well on both desktop and mobile when enabled
    - Remove any white patches or spacing issues
    
    **Settings Structure:**
    - Section-level settings for positioning, layout, padding, background, device visibility, and theme selection
    - Block-level settings for individual text items with their content, styling, links, and hover effects
    - Intuitive admin interface for easy content management
    - Proper sticky positioning that works below the header without white space issues, Apply and show Page width settings, Make it sticky

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    position: sticky;
    top: 0;
    z-index: 100;
    {% unless block.settings.show_on_mobile %}
      @media screen and (max-width: 749px) {
        display: none;
      }
    {% endunless %}
  }

  .ai-text-section__container-{{ ai_gen_id }} {
    {% if block.settings.page_width == 'full' %}
      max-width: 100%;
    {% elsif block.settings.page_width == 'narrow' %}
      max-width: 1000px;
    {% else %}
      max-width: {{ settings.page_width }}px;
    {% endif %}
    margin: 0 auto;
    display: flex;
    {% if block.settings.layout == 'vertical' %}
      flex-direction: column;
      gap: {{ block.settings.item_spacing }}px;
    {% else %}
      flex-direction: row;
      flex-wrap: wrap;
      gap: {{ block.settings.item_spacing }}px;
    {% endif %}
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;text-align: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
      text-align: right;
    {% else %}
      justify-content: flex-start;
      text-align: left;
    {% endif %}
    align-items: center;
  }

  .ai-text-section__item-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    text-decoration: none;
    transition: color 0.3s ease;
    {% if block.settings.layout == 'vertical' %}
      width: 100%;
    {% else %}
      white-space: nowrap;
    {% endif %}
  }

  .ai-text-section__item-{{ ai_gen_id }}:hover {
    color: {{ block.settings.hover_color }};
  }

  .ai-text-section__separator-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    {% if block.settings.layout == 'vertical' %}
      display: none;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-text-section__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'vertical' %}
        flex-direction: column;
      {% else %}
        flex-direction: row;
        flex-wrap: wrap;
      {% endif %}
    }

    .ai-text-section__separator-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'vertical' %}
        display: none;
      {% endif %}
    }

    .ai-text-section__item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-section__container-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign text_key = 'text_' | append: i
        assign link_key = 'link_' | append: i
        assign text_content = block.settings[text_key]
        assign link_url = block.settings[link_key]
      %}
      
      {% if text_content != blank %}
        {% if link_url != blank %}
          <a href="{{ link_url }}" class="ai-text-section__item-{{ ai_gen_id }}">
            {{ text_content }}
          </a>
        {% else %}
          <span class="ai-text-section__item-{{ ai_gen_id }}">
            {{ text_content }}
          </span>
        {% endif %}
        {% unless forloop.last %}
          {% assign next_index = forloop.index | plus: 1 %}
          {% liquid
            assign next_text_key = 'text_' | append: next_index
            assign next_text_content = block.settings[next_text_key]
          %}
          {% if next_text_content != blank and block.settings.show_separators %}
            <span class="ai-text-section__separator-{{ ai_gen_id }}">
              {% if block.settings.separator_type == 'bullet' %}
                •
              {% else %}
                |
              {% endif %}
            </span>
          {% endif %}
        {% endunless %}
      {% endif %}
    {% endfor %}
  </div>
</div>

